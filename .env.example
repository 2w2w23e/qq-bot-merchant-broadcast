# =============================
# NoneBot2 基础配置
# =============================
DRIVER=~fastapi+~websockets
HOST=0.0.0.0
PORT=8080

# =============================
# 远行商人插件配置
# =============================

# 推送目标群号（多群用英文逗号分隔，不要有空格）
MERCHANT_GROUPS=123456789,987654321

# 小黑盒目标用户 UID（默认：远行商人博主 98021738）
XHH_USER_ID=98021738

# 定时推送时间（24小时整点，英文逗号分隔）
MERCHANT_SCHEDULE_HOURS=9,13,17,21

# 爬取请求超时（秒）
XHH_REQUEST_TIMEOUT=15

# 爬取失败重试次数
XHH_RETRY_TIMES=3

# ── 测试模式 ─────────────────────────────────────────
# true：定时推送只发往测试群，不影响正式群；false：正常推送所有群
MERCHANT_TEST_MODE=false

# 测试专用群号（留空则取 MERCHANT_GROUPS 的第一个群）
MERCHANT_TEST_GROUP=
